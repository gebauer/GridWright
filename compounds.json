{
  "meta": {
    "name": "GridWright crystallization compound seed database",
    "version": 3,
    "purpose": "Typeahead source for reagent name + default stock concentration (and pKa for buffers). Used to prefill, not to lock — every value is editable by the user.",
    "stockNote": "Stock concentrations are typical crystallization-grade values (~Hampton Optimize line / near solubility at 25 C). They are sensible defaults to PREFILL; the user should confirm against the actual reagent bottle. Low-MW PEGs and neat organics are liquids expressed as % v/v; higher-MW PEGs as % w/v; salts/buffers as molar.",
    "pKaNote": "pKa values at 25 C from standard references. Polyprotic species list multiple pKa; the autocomplete should pick the pKa nearest the midpoint of the user's entered pH range (user-overridable).",
    "fields": {
      "name": "canonical display name",
      "aliases": "extra strings to match while typing",
      "category": "buffer | salt | polymer | organic",
      "stock": "{ value, unit } default stock concentration",
      "pKa": "array of pKa values (buffers only)"
    },
    "casMwNote": "CAS and MW are for the common anhydrous / free-acid form unless the name specifies a hydrate. MW is computed from formula. Hydration state changes MW — confirm against your actual reagent before weighing. MW/CAS are informational only and are not used in GridWright's volume calculation.",
    "hintNote": "Optional advisory text to display when a compound is selected in the UI.",
    "polymerNote": "Polymer MW is the nominal average; PEG CAS 25322-68-3 (PEG) / 9004-74-4 (PEG MME) are class-generic."
  },
